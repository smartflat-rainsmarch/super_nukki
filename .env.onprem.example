# On-premises environment configuration
# Copy to .env and fill in all values

# Database
DB_NAME=ui2psd
DB_USER=ui2psd
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Server
HOST_PORT=80
API_WORKERS=4
WORKER_CONCURRENCY=4

# Enterprise license
LICENSE_KEY=

# GPU (set true if NVIDIA GPU available)
GPU_ENABLED=false
